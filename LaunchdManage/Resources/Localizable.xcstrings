    "The folder '%@' was not found. launchd cannot create log files if their parent directory does not exist, which will block service loading." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The folder '%@' was not found. launchd cannot create log files if their parent directory does not exist, which will block service loading."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未找到目录“%@”。若日志文件的父目录不存在，launchd 将无法创建日志，这会导致服务加载失败。"
          }
        }
      }
    },
    "The path '%@' was not found on this system. Please check if the target script or application is installed." : {
